{
  "version": 2,
  "outputDirectory": ".",
  "routes": [
    { "src": "/api/(.*)", "dest": "https://littlanefinal.onrender.com/api/$1" },
    { "src": "/ticket-files/(.*)", "dest": "https://littlanefinal.onrender.com/ticket-files/$1" },
    { "src": "/assets/(.+)", "dest": "/app/assets/$1" },
    { "src": "/dashboard", "dest": "/app/index.html" },
    { "src": "/dashboard/(.*)", "dest": "/app/index.html" },
    { "src": "/dashhboard", "dest": "/app/index.html" },
    { "src": "/dashhboard/(.*)", "dest": "/app/index.html" },
    { "src": "/tickets", "dest": "/app/index.html" },
    { "src": "/tickets/(.*)", "dest": "/app/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
